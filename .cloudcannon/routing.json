{
  "routes": [
    {
      "from": "/.*",
      "to": "/404.html",
      "status": 404,
      "forced": false
    }
  ],
  "headers": [
    {
      "match": "/404.html",
      "headers": [
        {
          "name": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}
