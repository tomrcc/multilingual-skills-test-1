---
import RenderBlock from "@components/utils/renderBlock.astro";
import Button from "@core-elements/button/Button.astro";
import Heading from "@core-elements/heading/Heading.astro";
import Image from "@core-elements/image/Image.astro";
import Pagination from "@core-elements/pagination/Pagination.astro";
import SimpleText from "@core-elements/simple-text/SimpleText.astro";
import Page from "@layouts/Page.astro";
import CustomSection from "@page-sections/builders/custom-section/CustomSection.astro";
import BentoBoxGrid from "@wrappers/bento-box-grid/BentoBoxGrid.astro";
import BentoBoxGridItem from "@wrappers/bento-box-grid/BentoBoxGridItem.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";
import Card from "@wrappers/card/Card.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths({ paginate }) {
  const blogPosts = (await getCollection("blog")).sort(
    (a: any, b: any) => b.data.date.getTime() - a.data.date.getTime()
  );

  // Get all unique tags
  const allTags = Array.from(
    new Set(blogPosts.map((post: any) => post.data.tag).filter(Boolean))
  ).sort();

  // Generate paths for "all" posts
  return paginate(blogPosts, {
    pageSize: 8,
    props: { selectedTag: "all", allTags },
  });
}

const { page } = Astro.props;
const selectedTag = Astro.props.selectedTag || "all";
const allTags = Astro.props.allTags || [];

// Try to load blog page from pages collection for hero sections
let blogPage: any;

try {
  const pages = await getCollection("pages");

  blogPage = pages.find((page: any) => page.id === "blog");
} catch {}

const pageTitle = blogPage?.data?.title ?? "Blog";
const pageDescription =
  blogPage?.data?.description ??
  "Read our latest articles and insights on web development, design, and technology.";
const heroSections = blogPage?.data?.heroSections ?? [];
const ctaSections = blogPage?.data?.ctaSections ?? [];

const team = await getCollection("team");
---

<Page
  title={pageTitle}
  description={pageDescription}
>
  <div
    data-editable="array"
    data-prop="heroSections"
    data-component-key="_component"
    data-id-key="_component"
  >
    <RenderBlock contentSections={heroSections} />
  </div>

  <CustomSection
    id="posts"
    maxContentWidth="2xl"
    paddingHorizontal="lg"
    paddingVertical="2xl"
    colorScheme="light"
    backgroundColor="highlight-grid"
  >
    {
      page.data.length > 0 ? (
        <>
          {allTags.length > 0 && (
            <ButtonGroup>
              <Button
                link="/blog#posts"
                variant={selectedTag === "all" ? "secondary" : "base"}
                text="All"
                editable={false}
              />
              {allTags.map((tag: string) => (
                <Button
                  link={`/blog/tag/${tag}#posts`}
                  variant={selectedTag === tag ? "secondary" : "base"}
                  text={tag}
                  editable={false}
                />
              ))}
            </ButtonGroup>
          )}
          <BentoBoxGrid
            gap="sm"
            layout="start"
            minItemWidth="320"
            maxItemWidth="400"
            style="margin-top: var(--spacing-2xl)"
            editable={false}
            class="blog-grid"
          >
            {page.data.map((post: any, index: number) => {
              const pubDate = post.data.date.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              });

              // Get slug from id (for glob loader) or slug property (for default loader)
              const slug = post.id?.replace(/\.mdx?$/, "") || post.slug;

              // Set column span: first post is 7, second is 5, rest are 4
              const columnSpan = index === 0 ? 7 : index === 1 ? 5 : 4;

              // Get author page from uuid
              const author = team.find((m: any) => m.data.uuid === post.data.author);

              return (
                <BentoBoxGridItem
                  columnSpan={columnSpan}
                  editable={false}
                >
                  <Card
                    link={`/blog/${slug}`}
                    rounded={true}
                    border={false}
                    backgroundColor="accent"
                    paddingVertical="md"
                    paddingHorizontal="md"
                    editable={false}
                  >
                    {post.data.image && (
                      <Image
                        source={post.data.image}
                        alt={post.data.title}
                        aspectRatio="landscape"
                        editable={false}
                        rounded={true}
                        style="max-height: 230px; width: 100%;"
                      />
                    )}
                    <SimpleText
                      size="sm"
                      style="color: var(--color-text-brand); font-weight: var(--font-weight-bold); margin-bottom: var(--spacing-xs);"
                      editable={false}
                    >
                      {post.data.tag}
                    </SimpleText>
                    <Heading
                      level="h3"
                      size="md"
                      style="margin-bottom: var(--spacing-md); margin-top: var(--spacing-sm);"
                      editable={false}
                    >
                      {post.data.title}
                    </Heading>
                    <SimpleText
                      size="md"
                      style="margin-top: 0;"
                      editable={false}
                    >
                      {post.data.description}
                    </SimpleText>
                    <SimpleText
                      size="sm"
                      style="font-weight: var(--font-weight-bold); color: var(--color-text-muted); margin-bottom: var(--spacing-xs);"
                      editable={false}
                    >
                      By {author?.data.name || "Anonymous"} | {pubDate}
                    </SimpleText>
                  </Card>
                </BentoBoxGridItem>
              );
            })}
          </BentoBoxGrid>
          <Pagination
            page={page}
            showArrows={true}
            anchor="posts"
            style="margin-top: var(--spacing-2xl);"
          />
        </>
      ) : (
        <SimpleText
          alignmentHorizontal="center"
          style="margin-top: var(--spacing-2xl);"
          editable={false}
        >
          No blog posts yet. Check back soon!
        </SimpleText>
      )
    }
  </CustomSection>

  <div
    data-editable="array"
    data-prop="ctaSections"
    data-component-key="_component"
    data-id-key="_component"
  >
    <RenderBlock contentSections={ctaSections} />
  </div>
</Page>

<style is:global>
  @layer page-sections {
    .blog-grid .card .image .image-inner {
      max-height: 230px;
      width: 100%;
    }
  }
</style>
