---
import LibraryLayout from "@component-docs/layouts/LibraryLayout.astro";
import Page from "@layouts/Page.astro";
import ComponentBuilderInit from "@component-docs/components/ComponentBuilder/ComponentBuilderInit.astro";
import "@component-docs/components/ComponentBuilder/styles.css";

const isDisabled = process.env.DISABLE_COMPONENT_LIBRARY === "true";
const ssrEnabled = import.meta.env.DEV;

let componentDiscovery: any = null;
const metadataMapObj: Record<string, any> = {};
let nestedBlockPropertiesArray: any[] = [];
let BuilderComponent: any = null;

if (!isDisabled) {
  const componentBuilderModule =
    await import("@component-docs/components/ComponentBuilder/ComponentBuilder.astro");
  const componentDiscoveryModule =
    await import("@component-docs/components/ComponentBuilder/utils/componentDiscovery");
  const componentMetadataModule =
    await import("@component-docs/components/ComponentViewer/utils/componentMetadata");

  BuilderComponent = componentBuilderModule.default;
  componentDiscovery = await componentDiscoveryModule.discoverComponents();

  const metadataMap = await componentMetadataModule.getComponentMetadataMap();
  const nestedBlockProperties = await componentMetadataModule.getNestedBlockProperties();

  metadataMap.forEach((value: any, key: string) => {
    metadataMapObj[key] = value;
  });

  nestedBlockPropertiesArray = Array.from(nestedBlockProperties);
}
---

{
  isDisabled ? (
    <Page
      frontmatter={{
        title: "Component Builder",
        description:
          "The interactive Component Builder is available in local development or when you build with the component library enabled (npm run build:with-library).",
        noindex: true,
      }}
    >
      <section class="component-docs-disabled">
        <h1>Component Builder Available in Local Development</h1>
        <p>
          The Component Builder is disabled in this production build to keep the generated site lean
          and avoid loading the full component palette, sandbox, and discovery scripts on hosts that
          only publish marketing pages and blog content.
        </p>
        <p>
          Run <code>npm run dev</code> and open <code>/component-docs/component-builder/</code>{" "}
          locally to drag building blocks into the sandbox, edit props, preview nested layouts, and
          export a ready-to-drop-in Astro component package with CloudCannon configuration.
        </p>
        <p>
          To ship the builder in static output, run <code>npm run build:with-library</code> so the
          component library and builder routes are included alongside the rest of the site.
        </p>
      </section>
    </Page>
  ) : (
    <LibraryLayout
      frontmatter={{
        title: "Component Builder",
        contentSections: [],
        description:
          "Use the visual Component Builder to drag building blocks, configure props, and export Astro components with CloudCannon config—prototype page sections before writing code by hand.",
      }}
    >
      <BuilderComponent
        components={componentDiscovery.components}
        componentsByCategory={componentDiscovery.byCategory}
        metadataMap={metadataMapObj}
        nestedBlockProperties={nestedBlockPropertiesArray}
        nestingRules={componentDiscovery.nestingRules}
        pageSectionCategories={componentDiscovery.pageSectionCategories}
        ssrEnabled={ssrEnabled}
      />
      <ComponentBuilderInit />
    </LibraryLayout>
  )
}

<style is:global>
  .component-docs-disabled {
    margin: 0 auto;
    max-width: 50rem;
    padding: var(--spacing-4xl) var(--spacing-lg);
  }
</style>
