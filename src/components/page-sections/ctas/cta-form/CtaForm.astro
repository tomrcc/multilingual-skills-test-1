---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Icon from "@components/building-blocks/core-elements/icon/Icon.astro";
import Heading from "@core-elements/heading/Heading.astro";
import SimpleText from "@core-elements/simple-text/SimpleText.astro";
import Text from "@core-elements/text/Text.astro";
import Form from "@forms/form/Form.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";
import Split from "@wrappers/split/Split.astro";

const {
  id = "",
  eyebrowIcon = {},
  eyebrowText = "",
  heading = "",
  subtext = "",
  formAction = "./",
  formBlocks = [],
  buttonSections = [],
  reverse = false,
  maxContentWidth = "2xl",
  paddingVertical = "4xl",
  colorScheme = "inherit",
  backgroundColor,
  contentBackground = false,
  verticalOffset = {},
  rounded = false,
  class: className,
  _component,
  ...htmlAttributes
} = Astro.props;
---

<CustomSection
  class:list={["cta-form", className]}
  label={id}
  maxContentWidth={maxContentWidth}
  paddingHorizontal="lg"
  paddingVertical={paddingVertical}
  colorScheme={colorScheme}
  backgroundColor={backgroundColor}
  contentBackground={contentBackground}
  verticalOffset={verticalOffset}
  rounded={rounded}
  id={id}
  {...htmlAttributes}
>
  <Split
    class="split"
    distributionMode="two-thirds-third"
    alignmentVertical="center"
    reverse={reverse}
    minSplitWidth={640}
  >
    <Fragment slot="first">
      <Icon {...eyebrowIcon} />
      <SimpleText
        alignmentHorizontal="start"
        class="eyebrow"
        data-prop="eyebrowText"
      >
        {eyebrowText}
      </SimpleText>
      <Heading
        level="h2"
        size="xl"
        data-prop="heading"
        text={heading}
      />
      <Text
        alignmentHorizontal="start"
        data-prop="subtext"
        text={subtext}
        style="max-width: 540px;"
      />
      <ButtonGroup buttonSections={buttonSections} />
    </Fragment>
    <Fragment slot="second">
      <Form
        class="form"
        action={formAction}
        formBlocks={formBlocks}
        data-children-prop="formBlocks"
      />
    </Fragment>
  </Split>
</CustomSection>

<style is:global>
  @layer page-sections {
    .cta-form {
    }
  }
</style>
