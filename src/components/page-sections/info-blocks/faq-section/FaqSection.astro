---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Heading from "@core-elements/heading/Heading.astro";
import Accordion from "@wrappers/accordion/Accordion.astro";

const {
  heading = "Frequently Asked Questions",
  items = [],
  label = "About FAQ",
  sectionLabel,
  maxContentWidth = "xl",
  paddingHorizontal = "lg",
  paddingVertical = "4xl",
  colorScheme = "inherit",
  backgroundColor,
  background,
  class: className,
  _component,
  ...htmlAttributes
} = Astro.props;
---

<CustomSection
  {...htmlAttributes}
  class:list={["faq-section", className]}
  label={sectionLabel}
  maxContentWidth={maxContentWidth}
  paddingHorizontal={paddingHorizontal}
  paddingVertical={paddingVertical}
  colorScheme={colorScheme}
  backgroundColor={backgroundColor}
  background={background}
>
  <Heading
    level="h2"
    size="lg"
    alignmentHorizontal="center"
    text={heading}
    data-prop="heading"
  />

  <Accordion
    label={label}
    singleOpen={true}
    openFirst={false}
    items={items}
    data-children-prop="items"
  />
</CustomSection>
