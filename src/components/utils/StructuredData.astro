---
import { resolveImageSource } from "@component-utils/resolveImageSource";

export interface Props {
  site: {
    name: string;
    url: string;
    logoSource: string;
    description: string;
  };
}

const { site } = Astro.props;
const logoUrl = new URL(resolveImageSource(site.logoSource), site.url).toString();

const structuredData: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: site.name,
  url: site.url,
  logo: logoUrl,
  description: site.description,
};
---

<script
  type="application/ld+json"
  set:html={JSON.stringify(structuredData)}
/>
