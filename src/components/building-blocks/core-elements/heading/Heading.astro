---
import Icon from "@core-elements/icon/Icon.astro";
import MarkdownIt from "markdown-it";

const {
  text,
  level = "h2",
  size,
  alignmentHorizontal = "start",
  iconName,
  iconColor = "default",
  iconPosition = "before",
  class: className,
  useDefaultEditableBinding = false,
  "data-prop": customDataProp,
  "data-rosey": roseyProp,
  _component,
  ...htmlAttributes
} = Astro.props;

const effectiveDataProp = customDataProp ?? (useDefaultEditableBinding ? "text" : null);
const textDataAttributes = effectiveDataProp
  ? { "data-editable": "text", "data-type": "text", "data-prop": effectiveDataProp }
  : {};

// Auto-derive the Rosey translation key from the editing prop unless opted out
// with data-rosey={false}. Keeps translatable text tagged wherever this renders.
const effectiveDataRosey = roseyProp === false ? null : (roseyProp ?? effectiveDataProp ?? null);
const roseyAttributes = effectiveDataRosey ? { "data-rosey": effectiveDataRosey } : {};

const md = MarkdownIt({ html: true });
let MarkdownText = text ? md.renderInline(text) : "";

MarkdownText = MarkdownText.replace(/\n/g, "<br />");
const Tag = level;

const hasText = text?.trim().length > 0;
const hasSlotContent = Astro.slots.has("default");

if (!_component && !hasText && !hasSlotContent) return;
---

<Tag
  class:list={["heading", className]}
  {...htmlAttributes}
>
  <span class:list={["heading-inner", size && `size-${size}`, `align-${alignmentHorizontal}`]}>
    {
      iconPosition == "before" && (
        <Icon
          name={iconName}
          color={iconColor}
          size="none"
          class="heading-icon"
          aria-hidden="true"
          role="presentation"
        />
      )
    }
    <span
      class="heading-text"
      {...textDataAttributes}
      {...roseyAttributes}
    >
      <slot>
        {text && <Fragment set:html={MarkdownText} />}
      </slot>
    </span>
    {
      iconPosition === "after" && (
        <Icon
          name={iconName}
          color={iconColor}
          size="none"
          class="heading-icon heading-icon-after"
          aria-hidden="true"
          role="presentation"
        />
      )
    }
  </span>
</Tag>

<style is:global>
  @layer components {
    .heading {
      margin-top: var(--spacing-lg);

      > .heading-inner {
        display: block;

        .heading-icon {
          bottom: 0.1em;
          display: inline-block;
          font-size: 0.9em;
          position: relative;

          &.heading-icon-after {
            margin-inline: 0.2em 0;
          }
        }

        &.size-xs {
          font-size: var(--font-size-heading-xs);
        }

        &.size-sm {
          font-size: var(--font-size-heading-sm);
        }

        &.size-md {
          font-size: var(--font-size-heading-md);
        }

        &.size-lg {
          font-size: var(--font-size-heading-lg);
        }

        &.size-xl {
          font-size: var(--font-size-heading-xl);
        }

        &.size-2xl {
          font-size: var(--font-size-heading-2xl);
        }

        &.size-3xl {
          font-size: var(--font-size-heading-3xl);
        }

        &.size-4xl {
          font-size: var(--font-size-heading-4xl);
        }

        &.align-start {
          text-align: start;
        }

        &.align-center {
          text-align: center;
        }

        &.align-end {
          text-align: end;
        }
      }

      .highlight-text {
        color: var(--color-brand);
      }

      p {
        font-size: inherit;
      }
    }
  }
</style>
