---
const {
  title,
  text,
  class: className,
  useDefaultEditableBinding = false,
  "data-prop-title": customDataPropTitle,
  "data-prop-content": customDataPropContent,
  "data-rosey-title": roseyTitleProp,
  "data-rosey-content": roseyContentProp,
  _component,
  ...htmlAttributes
} = Astro.props;

const effectiveTitleProp = customDataPropTitle ?? (useDefaultEditableBinding ? "title" : null);
const titleDataAttributes = effectiveTitleProp
  ? { "data-editable": "text", "data-prop": effectiveTitleProp }
  : {};

const effectiveContentProp = customDataPropContent ?? (useDefaultEditableBinding ? "text" : null);
const contentDataAttributes = effectiveContentProp
  ? { "data-editable": "text", "data-prop": effectiveContentProp }
  : {};

// Auto-derive Rosey keys for both the term and definition unless opted out.
const effectiveTitleRosey =
  roseyTitleProp === false ? null : (roseyTitleProp ?? effectiveTitleProp ?? null);
const titleRoseyAttributes = effectiveTitleRosey ? { "data-rosey": effectiveTitleRosey } : {};
const effectiveContentRosey =
  roseyContentProp === false ? null : (roseyContentProp ?? effectiveContentProp ?? null);
const contentRoseyAttributes = effectiveContentRosey
  ? { "data-rosey": effectiveContentRosey }
  : {};

const hasTitle = title?.trim().length > 0;
const hasTitleSlotContent = Astro.slots.has("title");
const hasText = text?.trim().length > 0;
const hasSlotContent = Astro.slots.has("default");

if (!_component && ((!hasTitle && !hasTitleSlotContent) || (!hasText && !hasSlotContent))) return;
---

<div
  class="definition-list-item"
  {...htmlAttributes}
>
  <dt
    class:list={["title", className]}
    role="term"
    {...titleDataAttributes}
  >
    <span {...titleDataAttributes} {...titleRoseyAttributes}>
      <slot name="title">
        {title}
      </slot>
    </span>
  </dt>
  <dd
    class:list={["content", className]}
    role="definition"
  >
    <span {...contentDataAttributes} {...contentRoseyAttributes}>
      <slot>
        {text}
      </slot>
    </span>
  </dd>
</div>

<style is:global>
  @layer components {
    .definition-list-item {
      align-items: inherit;
      display: grid;
      grid-column: 1 / -1;
      grid-template-columns: subgrid;

      > .title {
        font-weight: var(--font-weight-bold);
      }
    }
  }
</style>
