---
import Icon from "@core-elements/icon/Icon.astro";
import MarkdownIt from "markdown-it";

const {
  text = "",
  iconName,
  iconColor = "default",
  showIcon = true,
  link,
  class: className,
  useDefaultEditableBinding = false,
  "data-prop": customDataProp,
  "data-rosey": roseyProp,
  _component,
  ...htmlAttributes
} = Astro.props;

const md = new MarkdownIt({ html: true });

const effectiveDataProp = customDataProp ?? (useDefaultEditableBinding ? "text" : null);
const textDataAttributes = effectiveDataProp
  ? { "data-editable": "text", "data-prop": effectiveDataProp }
  : {};

// Auto-derive the Rosey translation key from the editing prop unless opted out.
const effectiveDataRosey = roseyProp === false ? null : (roseyProp ?? effectiveDataProp ?? null);
const roseyAttributes = effectiveDataRosey ? { "data-rosey": effectiveDataRosey } : {};

const hasIcon = showIcon && iconName;
---

<li
  class:list={["item", className, hasIcon && "list-item-has-icon"]}
  {...htmlAttributes}
>
  {
    hasIcon && (
      <Icon
        name={iconName}
        color={iconColor}
        size="none"
        class="list-icon"
        aria-hidden="true"
      />
    )
  }
  {
    link ? (
      <a
        href={link}
        class="item-inner"
      >
        <p {...textDataAttributes} {...roseyAttributes}>
          {text ? <Fragment set:html={md.renderInline(text)} /> : <slot />}
        </p>
      </a>
    ) : (
      <span class="item-inner">
        <p {...textDataAttributes} {...roseyAttributes}>
          {text ? <Fragment set:html={md.renderInline(text)} /> : <slot />}
        </p>
      </span>
    )
  }
</li>

<style is:global>
  @layer components {
    .item {
      &.list-item-has-icon {
        display: flex;
        align-items: baseline;
      }

      > .list-icon {
        display: inline-block;
        flex-shrink: 0;
        height: 1em;
        margin-inline-end: var(--spacing-em-xs);
        translate: 0 0.15em;
        width: 1em;

        svg {
          display: block;
          height: 100%;
          width: 100%;
        }
      }

      > .item-inner {
        min-width: 0;

        > p {
          display: inline;
          font-size: inherit;
          margin: 0;
        }
      }

      > a.item-inner:any-link > p {
        color: inherit;
      }

      > a.item-inner:any-link:focus-visible {
        border-radius: var(--radius-sm);
        outline: 2px solid currentColor;
        outline-offset: 2px;
      }
    }
  }
</style>
