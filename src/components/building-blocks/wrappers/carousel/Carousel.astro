---
import Button from "@core-elements/button/Button.astro";
import CarouselSlide from "./CarouselSlide.astro";
import { slugifyLabel } from "@components/utils/slugify";

type SlideProps = Record<string, unknown>;

const {
  slides = [],
  autoPlay = false,
  autoScroll = false,
  showIndicators = true,
  /** `"dots"` (default) or `"fraction"` (e.g. `1/3`). */
  indicatorStyle = "dots",
  showArrows = true,
  loop = true,
  alignmentHorizontal = "center",
  slidesToScroll = "auto",
  slideWidthPercent = 100,
  minSlideWidth = 0,
  gap = "none",
  style = "",
  label,
  "data-children-prop": childrenDataProp,
  editable = false,
  _component,
  class: className,
  ...htmlAttributes
} = Astro.props;

if (!htmlAttributes.id && label) {
  htmlAttributes.id = slugifyLabel(label);
}

const dataAttributes: Record<string, string> = {};

const effectiveShowIndicators = autoScroll ? false : showIndicators;
const effectiveShowArrows = autoScroll ? false : showArrows;

dataAttributes["data-show-indicators"] = String(effectiveShowIndicators);
dataAttributes["data-show-arrows"] = String(effectiveShowArrows);
dataAttributes["data-loop"] = String(loop);
dataAttributes["data-align"] = String(alignmentHorizontal);
dataAttributes["data-slides-to-scroll"] = String(slidesToScroll);

if (autoPlay) {
  dataAttributes["data-autoplay"] = "3";
}

if (autoScroll) {
  dataAttributes["data-autoscroll"] = "1";
}

const effectiveChildrenProp = childrenDataProp ?? (editable ? "slides" : null);
const arrayDataAttributes = effectiveChildrenProp
  ? { "data-editable": "array", "data-prop": effectiveChildrenProp }
  : {};

const carouselClasses = "carousel";

const slideGap = gap === "none" ? "0px" : `var(--spacing-${gap})`;

// Build the style attribute, merging custom styles with CSS variables
const carouselStyles = `
  --slide-width: ${slideWidthPercent}%;
  --min-slide-width: ${minSlideWidth}px;
  --slide-gap: ${slideGap};
  ${style}
`.trim();

const hasSlides = slides?.length > 0;
const hasSlotContent = Astro.slots.has("default");

if (!_component && !hasSlides && !hasSlotContent) return;
---

<section
  class:list={[carouselClasses, className]}
  role="region"
  aria-label={label || "Carousel"}
  {...htmlAttributes}
>
  <div
    class="carousel-inner"
    style={carouselStyles}
    {...dataAttributes}
  >
    <div class="viewport">
      <div
        class="track"
        {...arrayDataAttributes}
      >
        <slot>
          {
            slides?.map((slide: SlideProps, index: number) => (
              <CarouselSlide
                {...slide}
                data-editable="array-item"
                data-id="building-blocks/wrappers/carousel/carousel-slide"
                editable={!!effectiveChildrenProp}
                aria-label={`Slide ${index + 1} of ${slides.length}`}
              />
            ))
          }
        </slot>
      </div>
    </div>

    {
      (effectiveShowArrows || effectiveShowIndicators) && (
        <div class="controls-wrapper">
          {effectiveShowArrows && (
            <Button
              iconName="chevron-left"
              size="none"
              variant="tertiary"
              hideText={true}
              aria-label="Previous slide"
              class="prev"
              element="button"
            />
          )}

          {effectiveShowIndicators &&
            (indicatorStyle === "fraction" ? (
              <div
                class="carousel-fraction"
                aria-live="polite"
                aria-atomic="true"
              />
            ) : (
              <div class="indicators" />
            ))}

          {effectiveShowArrows && (
            <Button
              iconName="chevron-right"
              size="none"
              variant="tertiary"
              hideText={true}
              aria-label="Next slide"
              class="next"
              element="button"
            />
          )}
        </div>
      )
    }
  </div>
</section>

<script>
  import { onPageLoad } from "@component-utils/onPageLoad";
  import { setupAllCarousels } from "./setup";

  onPageLoad(() => setupAllCarousels());
</script>

<style is:global>
  @layer components {
    .carousel {
      margin-top: var(--spacing-lg);
      width: 100%;

      > .carousel-inner {
        position: relative;
        --slide-width: 100%;
        --min-slide-width: 0px;
        --slide-gap: 0px;

        > .viewport {
          overflow: hidden;
          position: relative;
          width: 100%;
        }

        > .viewport > .track {
          display: flex;
          flex-wrap: nowrap;
          margin-inline-start: calc(var(--slide-gap) * -1);

          > .slide {
            flex-basis: calc(max(var(--slide-width, 100%), var(--min-slide-width, 0px)));
            flex-shrink: 0;
            padding-inline-start: var(--slide-gap);
            width: 100%;
          }
        }

        > .controls-wrapper {
          align-items: center;
          display: flex;
          gap: var(--spacing-md);
          justify-content: center;
          margin-bottom: var(--spacing-sm);
          margin-top: var(--spacing-sm);

          svg {
            width: 18px;
            height: 18px;
          }
        }

        > .controls-wrapper > .prev > .button-inner,
        > .controls-wrapper > .next > .button-inner {
          background-color: var(--color-bg);
          border-radius: var(--radius-full);
          flex-shrink: 0;
          pointer-events: auto;

          &:hover {
            background-color: var(--color-bg-surface);
          }
        }

        > .controls-wrapper > .indicators {
          display: flex;
          gap: var(--spacing-sm);
          justify-content: center;
        }

        > .controls-wrapper > .indicators > .indicator {
          aspect-ratio: 1/1;
          background-color: var(--color-border);
          border: none;
          border-radius: var(--radius-full);
          cursor: pointer;
          min-height: 0;
          min-width: 0;
          padding: 0;
          transition:
            transform var(--animation-normal) ease,
            background-color var(--animation-normal) ease;
          width: 8px;

          &[data-selected="true"] {
            background-color: var(--color-brand-muted);
            transform: scale(1.2);
          }
        }

        &[data-show-indicators="false"] {
          > .controls-wrapper > .indicators,
          > .controls-wrapper > .carousel-fraction {
            display: none;
          }
        }

        > .controls-wrapper > .carousel-fraction {
          color: var(--color-text-muted);
          flex-shrink: 0;
          font-size: var(--font-size-sm);
          font-variant-numeric: tabular-nums;
          line-height: 1.2;
          min-width: 3ch;
          text-align: center;
        }

        &[data-show-arrows="false"] {
          .controls-wrapper > .prev,
          .controls-wrapper > .next {
            display: none !important;
          }
        }
      }
    }
  }
</style>
