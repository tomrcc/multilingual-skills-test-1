---
import BentoBoxGridItem from "./BentoBoxGridItem.astro";

const {
  layout = "center",
  class: className,
  style: userStyle,
  items = [],
  label,
  gap = "md",
  useDefaultEditableBinding = false,
  _component,
  "data-children-prop": childrenDataProp,
  ...htmlAttributes
} = Astro.props;

const slugifyLabel = (label: string) => {
  return label
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
};

if (!htmlAttributes.id && label) {
  htmlAttributes.id = slugifyLabel(label);
}

const gridStyles = [`--grid-spacing: var(--spacing-${gap})`, userStyle].filter(Boolean).join("; ");

const effectiveChildrenProp = childrenDataProp ?? (useDefaultEditableBinding ? "items" : null);
const arrayDataAttributes = effectiveChildrenProp
  ? {
      "data-editable": "array",
      "data-prop": effectiveChildrenProp,
    }
  : {};

const hasItems = items?.length > 0;
const slotContent = Astro.slots.has("default") ? await Astro.slots.render("default") : null;
const hasSlotContent = (slotContent?.toString().trim().length ?? 0) > 0;

if (!_component && !hasItems && !hasSlotContent) return;
---

<div
  class:list={["bento-box-grid", className]}
  {...htmlAttributes}
>
  <div
    {...arrayDataAttributes}
    class:list={["bento-box-grid-inner", `layout-${layout}`]}
    style={gridStyles}
  >
    <slot>
      {
        items?.map((item: any) => (
          <BentoBoxGridItem
            data-id="building-blocks/wrappers/bento-box-grid/bento-box-grid-item"
            data-editable="array-item"
            class:list={`layout-${layout}`}
            useDefaultEditableBinding={!!effectiveChildrenProp}
            {...item}
          />
        ))
      }
    </slot>
  </div>
</div>

<style>
  @layer components {
    .bento-box-grid {
      margin-top: var(--spacing-lg);
      width: 100%;
    }

    .bento-box-grid > .bento-box-grid-inner {
      display: grid;
      gap: var(--grid-spacing, var(--spacing-md));
      grid-template-columns: repeat(12, 1fr);
      width: 100%;
    }
  }
</style>
