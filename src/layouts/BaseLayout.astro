---
import { ClientRouter } from "astro:transitions";
import { fade } from "astro:transitions";
import SeoHead from "@components/utils/SeoHead.astro";
import StructuredData from "@components/utils/StructuredData.astro";
import seoData from "@data/seo.json";
import "@styles/style.css";
import SiteFonts from "@layouts/SiteFonts.astro";
import VideoElements from "@components/utils/VideoElements.astro";

export interface Props {
  title: string;
  description?: string | null;
  keywords?: string[] | null;
  image?: string | null;
  canonical?: string | null;
  type?: "website" | "article";
  article?: {
    publishedTime?: string | null;
    modifiedTime?: string | null;
    author?: string | string[] | null;
    tags?: string[] | null;
  } | null;
  noindex?: boolean;
}

const props = Astro.props;
---

<!doctype html>
<html
  lang="en"
  data-theme="light"
>
  <head>
    <script is:inline>
      // Set text direction before first paint for RTL locales (e.g. Arabic).
      // Rosey sets <html lang> on translated pages; this reads it to flip dir.
      const rtl = new Set(["ar", "he", "fa", "ur", "ps", "sd", "yi", "ku", "ckb", "dv", "ug"]);
      const lang = document.documentElement.lang?.split("-")[0];
      if (rtl.has(lang)) document.documentElement.dir = "rtl";
    </script>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <link
      rel="icon"
      type="image/svg+xml"
      href="/favicon.svg"
    />
    <meta
      name="generator"
      content={Astro.generator}
    />
    <style is:inline>
      @layer reset, base, components, page-sections, utils, overrides;
    </style>

    <SiteFonts />

    {
      import.meta.env.DEV ? (
        <script
          type="module"
          src="/@vite/client"
        />
      ) : null
    }

    <!-- Preload fonts -->
    <link
      rel="preload"
      href="/fonts/Inter/inter-v20-latin-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/JetBrains Mono/jetbrains-mono-v24-latin-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <script>
      if (window.inEditorMode) {
        import("../../live-editing");
        import("../../editor-live-sync");
      }
    </script>

    <SeoHead
      site={seoData}
      title={props.title}
      description={props.description}
      keywords={props.keywords}
      image={props.image}
      canonical={props.canonical}
      type={props.type}
      article={props.article}
      noindex={props.noindex}
    />

    <StructuredData site={seoData} />

    <link
      rel="sitemap"
      type="application/xml"
      title="Sitemap"
      href="/sitemap-index.xml"
    />

    <slot name="head" />
    <ClientRouter />
  </head>
  <body>
    <!-- data-rcc marks the snapshot boundary the RCC clones when switching locales
         in CloudCannon's Visual Editor. It wraps nav + main + footer (all rendered
         into the slot) so their translatable text switches too. -->
    <div
      data-rcc
      transition:animate={fade({ duration: "0.2s" })}
    >
      <slot />
    </div>
    <VideoElements />
    <!-- Lazy-load the Rosey CloudCannon Connector only inside the editor. -->
    <script>
      if (window?.inEditorMode) {
        import("rosey-cloudcannon-connector");
      }
    </script>
  </body>
</html>
