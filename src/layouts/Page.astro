---
import Footer from "@components/navigation/footer/Footer.astro";
import MainNavigation from "@components/navigation/main-nav/MainNav.astro";
import ThemeToggleScript from "@components/navigation/theme-toggle/ThemeToggleScript.astro";
import MainComponent from "@components/utils/MainComponent.astro";
import footerData from "@data/footer.json";
import mainNavData from "@data/mainNav.json";
import Layout from "@layouts/BaseLayout.astro";

import type { ContentBlock } from "../types";

type Props = {
  frontmatter?: {
    title: string;
    description?: string;
    keywords?: string[];
    image?: string;
    canonical?: string;
    type?: "website" | "article";
    article?: {
      publishedTime?: string;
      modifiedTime?: string;
      author?: string | string[];
      tags?: string[];
    };
    pageSections?: ContentBlock[];
    noindex?: boolean;
  };
  title?: string;
  description?: string;
  keywords?: string[];
  image?: string;
  canonical?: string;
  type?: "website" | "article";
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    author?: string | string[];
    tags?: string[];
  };
  noindex?: boolean;
  disablePagefind?: boolean;
  mainNav?: Record<string, unknown>;
  footer?: Record<string, unknown>;
  /**
   * Rosey namespace root for this page. Defaults to the URL-derived slug.
   * Split-by-directory locale pages pass the English-equivalent path (e.g.
   * "blog/my-post") so their keys align with the source-language keys.
   */
  roseyRoot?: string;
};

const {
  frontmatter,
  title: titleProp,
  description: descriptionProp,
  keywords: keywordsProp,
  image: imageProp,
  canonical: canonicalProp,
  type: typeProp,
  article: articleProp,
  noindex: noindexProp,
  disablePagefind = false,
  mainNav = mainNavData,
  footer = footerData,
  roseyRoot,
} = Astro.props as Props;

// Rosey namespace root: strip leading/trailing slashes from the URL path and, for
// prefixed locales, drop the leading locale segment so keys match the source
// language. Home page falls back to "index".
const knownLocales = ["en", "es", "ar"];
const derivedSlug =
  Astro.url.pathname
    .replace(/^\/|\/$/g, "")
    .replace(new RegExp(`^(${knownLocales.join("|")})(/|$)`), "") || "index";
const pageRoseyRoot = roseyRoot ?? derivedSlug;

const title = frontmatter?.title ?? titleProp ?? "";
const description = frontmatter?.description ?? descriptionProp;
const keywords = frontmatter?.keywords ?? keywordsProp;
const image = frontmatter?.image ?? imageProp;
const canonical = frontmatter?.canonical ?? canonicalProp;
const type = frontmatter?.type ?? typeProp;
const article = frontmatter?.article ?? articleProp;
const noindex = frontmatter?.noindex ?? noindexProp ?? false;
const sections = frontmatter?.pageSections ?? [];
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  image={image}
  canonical={canonical}
  type={type}
  article={article}
  noindex={noindex}
>
  {mainNav.themeToggle && <ThemeToggleScript slot="head" />}
  <MainNavigation {...mainNav} />

  <main
    data-rosey-root={pageRoseyRoot}
    {...disablePagefind ? { "data-pagefind-ignore": "all" } : {}}
  >
    {
      sections.length > 0 && (
        <div
          data-editable="component"
          data-component="utils/main-component"
          data-prop-sections="pageSections"
        >
          <MainComponent sections={sections} />
        </div>
      )
    }
    <div {...disablePagefind ? {} : { "data-pagefind-body": true }}>
      <slot />
    </div>
  </main>
  <Footer {...footer} />
</Layout>
