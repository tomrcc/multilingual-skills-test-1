{
  "name": "jetstream-astro-template",
  "type": "module",
  "version": "1.0.0",
  "description": "Jetstream is a polished, high-performance marketing website template for Astro.",
  "keywords": [
    "astro",
    "cloudcannon",
    "ssg",
    "astro-theme",
    "astrojs",
    "astro-template",
    "astro-themes",
    "cloudcannon-themes",
    "ssg-astro"
  ],
  "author": "CloudCannon",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "DISABLE_COMPONENT_DOCS=true astro build",
    "build:with-docs": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "npm run lint && npm run format",
    "check:fix": "npm run lint:fix && npm run format:fix",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:yml",
    "lint:js": "eslint .",
    "lint:yml": "eslint \"**/*.{yml,yaml}\"",
    "lint:fix": "npm run lint:js:fix && npm run lint:css:fix && npm run lint:yml:fix",
    "lint:js:fix": "eslint . --fix",
    "lint:yml:fix": "eslint \"**/*.{yml,yaml}\" --fix",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "stylelint \"**/*.css\" --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "deps:sync": "rm -rf node_modules && npm install --os=linux --cpu=x64 --libc=glibc --ignore-scripts --no-audit && npm ci",
    "deps:check": "npm ci --dry-run"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/compiler-rs": "^0.1.10",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/node": "^10.0.6",
    "@astrojs/sitemap": "^3.7.2",
    "@choctawnationofoklahoma/lite-vimeo": "^1.3.1",
    "@cloudcannon/editable-regions": "^0.0.14",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/raleway": "^5.2.8",
    "@justinribeiro/lite-youtube": "^1.9.0",
    "@types/js-yaml": "^4.0.9",
    "astro": "^6.1.10",
    "astro-icon": "^1.1.5",
    "embla-carousel": "^8.6.0",
    "embla-carousel-auto-scroll": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "glob": "^13.0.6",
    "js-beautify": "^1.15.4",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "markdown-it": "^14.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rosey": "^2.3.10",
    "rosey-cloudcannon-connector": "github:tomrcc/rcc-v2",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "typescript": "^6.0.3",
    "unpic": "^4.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-yml": "^3.3.1",
    "jsonc-eslint-parser": "^3.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "stylelint": "^17.9.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "yaml-eslint-parser": "^2.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "optionalDependencies": {
    "@img/sharp-linux-x64": "^0.34.5",
    "@img/sharp-linuxmusl-x64": "^0.34.5",
    "@rollup/rollup-linux-x64-gnu": "^4.60.2",
    "@rollup/rollup-win32-x64-msvc": "^4.60.2"
  }
}
